<!-- VISITOR CONNECT CARD -->
<section id="connect-card" style="max-width: 500px; margin: 20px auto; padding: 20px; border: 1px solid #ccc; border-radius: 8px;">
    <h2>Visitor Connect Card</h2>
    <p>We are so glad you visited West Village! Let us know how we can serve you.</p>
    
    <form id="visitorForm">
        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold;">Full Name *</label>
            <input type="text" name="fullName" required style="width: 100%; padding: 8px; box-sizing: border-box;">
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold;">Email Address *</label>
            <input type="email" name="email" required style="width: 100%; padding: 8px; box-sizing: border-box;">
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold;">Phone Number</label>
            <input type="tel" name="phone" style="width: 100%; padding: 8px; box-sizing: border-box;">
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold;">How did you hear about us?</label>
            <input type="text" name="heardAboutUs" placeholder="Friend, flyer, social media, etc." style="width: 100%; padding: 8px; box-sizing: border-box;">
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold;">Comments or Questions</label>
            <textarea name="comments" rows="4" style="width: 100%; padding: 8px; box-sizing: border-box;"></textarea>
        </div>

        <button type="submit" style="background-color: #2b4c7e; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">
            Submit Connect Card
        </button>
    </form>
</section>
